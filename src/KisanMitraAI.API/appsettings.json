{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AWS": {
    "Profile": "your-aws-profile",
    "Region": "us-east-1",
    "Transcribe": {
      "ServiceURL": "https://transcribe.us-east-1.amazonaws.com"
    },
    "Bedrock": {
      "ServiceURL": "https://bedrock-runtime.us-east-1.amazonaws.com",
      "ModelId": "us.amazon.nova-pro-v1:0"
    },
    "Rekognition": {
      "ServiceURL": "https://rekognition.us-east-1.amazonaws.com"
    },
    "Textract": {
      "ServiceURL": "https://textract.us-east-1.amazonaws.com"
    },
    "Polly": {
      "ServiceURL": "https://polly.us-east-1.amazonaws.com"
    },
    "S3": {
      "ServiceURL": "https://s3.us-east-1.amazonaws.com",
      "BucketName": "your-s3-bucket-name",
      "QuarantineBucket": "your-quarantine-bucket-name"
    },
    "DynamoDB": {
      "ServiceURL": "https://dynamodb.us-east-1.amazonaws.com"
    },
    "StepFunctions": {
      "ServiceURL": "https://states.us-east-1.amazonaws.com"
    },
    "Cognito": {
      "UserPoolId": "your-user-pool-id",
      "ClientId": "your-client-id"
    },
    "KMS": {
      "KeyId": "arn:aws:kms:us-east-1:XXXXXXXXXXXX:key/XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
    },
    "Lambda": {
      "MalwareScannerArn": "arn:aws:lambda:us-east-1:XXXXXXXXXXXX:function:clamav-scanner"
    }
  },
  "Cognito": {
    "UserPoolId": "your-user-pool-id",
    "ClientId": "your-client-id",
    "Region": "us-east-1",
    "MaxRetryAttempts": 3,
    "RetryDelayMilliseconds": 1000,
    "RecaptchaSecretKey": "YOUR_RECAPTCHA_SECRET_KEY_HERE"
  },
  "DynamoDB": {
    "Region": "us-east-1",
    "UserProfileTableName": "KisanMitraAI-UserProfiles",
    "OfflineQueueTableName": "KisanMitraAI-OfflineQueue",
    "SessionTableName": "KisanMitraAI-Sessions",
    "SoilDataHistoryTableName": "your-soil-data-table",
    "MandiPricesHistoryTableName": "your-mandi-prices-table",
    "GradingHistoryTableName": "your-grading-history-table",
    "MaxExchangesPerSession": 10,
    "SessionExpirationHours": 24,
    "MaxQueueSizeBytes": 52428800
  },
  "KnowledgeBase": {
    "KnowledgeBaseId": "YOUR_KB_ID",
    "MaxResults": 10
  },
  "RateLimiting": {
    "RequestsPerMinutePerFarmer": 100
  },
  "Weather": {
    "ApiKey": "YOUR_OPENWEATHER_API_KEY_HERE",
    "ApiBaseUrl": "https://api.openweathermap.org/data/2.5"
  }
}
